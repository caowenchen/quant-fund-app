# QQ邮箱配置 (用于接收交易信号邮件)
QQ_EMAIL=your_qq@qq.com
QQ_EMAIL_AUTH_CODE=your_authorization_code

# 数据库路径
DATABASE_URL=sqlite:///quant_fund.db

# 服务器配置
HOST=0.0.0.0
PORT=5000
DEBUG=true

# ====== 雷电模拟器配置 ======
# 雷电模拟器默认ADB端口 5555 (多开: 5557, 5559...)
LDPLAYER_ADB_PORT=5555
# 雷电安装路径 (自动检测, 手动指定覆盖)
LDPLAYER_PATH=
# 模拟器实例编号 (0=默认)
LDPLAYER_INSTANCE=0

# 安全开关: 自动抓取后是否需要确认才写入数据库 (true=需要确认, false=自动写入)
AUTO_IMPORT_CONFIRM=true

# 支付宝自动抓取 (默认false=关闭, 实验功能)
AUTO_ALIPAY_SCRAPE=false

# 持仓数据源: manual / csv / alipay_candidate
HOLDING_SOURCE=manual

# 手动管理开关
ENABLE_MANUAL_IMPORT=true
ENABLE_CSV_IMPORT=true

# ====== 自动抓取依赖 (选装) ======
# 方案A (推荐): uiautomator2
#   pip install uiautomator2
#   python -m uiautomator2 init
# 方案B: OCR识别
#   pip install pytesseract Pillow
#   下载安装 Tesseract-OCR: https://github.com/UB-Mannheim/tesseract/wiki
